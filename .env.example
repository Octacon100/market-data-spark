# ============================================================================
# Market Data Pipeline with Spark on EMR - Environment Configuration
# ============================================================================

# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git (it's in .gitignore)

# ============================================================================
# Required Configuration
# ============================================================================

# Alpha Vantage API Key (get free at: https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# AWS S3 Bucket (create with: aws s3 mb s3://your-bucket-name)
S3_BUCKET=your-s3-bucket-name

# AWS Region
AWS_REGION=us-east-1

# ============================================================================
# Optional Configuration
# ============================================================================

# Stock symbols to track (comma-separated)
# NOTE: Symbols are now loaded from config/watchlist.json by default.
# This env var overrides the JSON file if set.
SYMBOLS=AAPL,GOOGL,MSFT,AMZN,TSLA

# EMR Configuration
EMR_KEY_PAIR=your-ec2-key-pair-name
EMR_SUBNET_ID=subnet-xxxxxxxxxxxxxxxxx
EMR_MASTER_INSTANCE_TYPE=m5.xlarge
EMR_CORE_INSTANCE_TYPE=m5.xlarge
EMR_CORE_INSTANCE_COUNT=2

# EMR Spot Instance Configuration
USE_SPOT_INSTANCES=True
SPOT_BID_PRICE=0.15

# Auto-termination (seconds)
AUTO_TERMINATE_IDLE_SECONDS=3600

# Prefect Cloud (if using Prefect Cloud instead of self-hosted)
# PREFECT_API_URL=https://api.prefect.cloud
# PREFECT_API_KEY=your_prefect_api_key

# ============================================================================
# Advanced Configuration (usually don't need to change)
# ============================================================================

# EMR Release Version
EMR_RELEASE_LABEL=emr-7.3.0

# IAM Roles (use defaults if not specified)
# EMR_SERVICE_ROLE=EMR_DefaultRole
# EMR_INSTANCE_PROFILE=EMR_EC2_DefaultRole

# Logging
LOG_LEVEL=INFO
PREFECT_LOGGING_LEVEL=INFO

# ============================================================================
# Buy Signal Email Alerts (via AWS SES)
# ============================================================================

# SES verified sender email address
# ALERT_EMAIL_SENDER=alerts@yourdomain.com

# Recipients are configured in config/pipeline_settings.json
# Enable email by setting alerts.email_enabled=true in pipeline_settings.json
# Both sender and recipients must be verified in AWS SES console

# ============================================================================
# Claude AI (Daily Digest Synopsis)
# ============================================================================

# Anthropic API Key for Claude AI stock analysis
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Gmail SMTP for email alerts and daily digest
ALERT_EMAIL_FROM=your_gmail@gmail.com
ALERT_EMAIL_TO=recipient@gmail.com
GMAIL_APP_PASSWORD=your_google_app_password_here

# ============================================================================
# Development Settings
# ============================================================================

# Set to 'dev' or 'prod'
ENVIRONMENT=dev

# Enable debug mode (more verbose logging)
DEBUG=False
