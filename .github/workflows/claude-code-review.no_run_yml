name: Claude Code - PR Review

on:
  pull_request:
    types: [opened, synchronize]

jobs:
  review:
    runs-on: ubuntu-latest
    timeout-minutes: 15

    permissions:
      contents: read
      pull-requests: write

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Claude Code Review
        uses: anthropics/claude-code-action@v1
        with:
          model: "claude-sonnet-4-20250514"
          prompt: |
            Review this pull request. Check for:
            - Bugs or logic errors
            - Security issues (command injection, credential exposure)
            - Adherence to project conventions in CLAUDE.md
            - PowerShell script standards (ASCII encoding, CRLF, no Unicode)

            Be concise. Only comment on real issues, not style preferences.
          allowed_tools: "Read,Glob,Grep"
        env:
          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
