{
    "buy_signals": {
        "enabled": true,
        "rules": {
            "golden_cross": {
                "enabled": true,
                "description": "7-day MA crosses above 30-day MA"
            },
            "momentum_surge": {
                "enabled": true,
                "description": "7-day momentum exceeds threshold",
                "min_momentum_pct": 3.0
            },
            "oversold_bounce": {
                "enabled": true,
                "description": "Price recovers above 30-day MA after dipping below",
                "ma_field": "ma_30d"
            },
            "low_vol_uptrend": {
                "enabled": true,
                "description": "Low volatility with positive momentum (stable uptrend)",
                "max_volatility_7d_pct": 2.0,
                "min_momentum_pct": 1.0
            }
        }
    },
    "alerts": {
        "email_enabled": true,
        "recipients": ["octacon100@gmail.com"]
    },
    "reddit_scanner": {
        "subreddits": ["wallstreetbets", "stocks", "investing"],
        "scan_lookback_hours": 24,
        "min_mention_threshold": 2,
        "auto_add_top_n": 5,
        "min_mentions": 10
    },
    "daily_digest": {
        "enabled": true,
        "schedule": "0 7 * * 1-5",
        "timezone": "America/New_York",
        "top_n_reddit": 10,
        "top_n_movers": 10
    }
}
